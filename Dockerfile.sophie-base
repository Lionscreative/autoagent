FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
  && rm -rf /var/lib/apt/lists/*

# Python deps for the verifier
RUN pip install --no-cache-dir groq httpx

# Copy the shared verifier library so tasks can import it
RUN mkdir -p /tasks-sophie
COPY tasks-sophie/_verifier_lib.py /tasks-sophie/_verifier_lib.py

# Harbor mounts the task dir at runtime; this is just a warm slot
WORKDIR /task
RUN mkdir -p /logs/verifier

ENV PYTHONPATH=/tasks-sophie:/task
