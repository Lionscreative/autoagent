FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates git curl && \
    rm -rf /var/lib/apt/lists/*

# Install Node.js 20 LTS
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y nodejs && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Python deps
COPY pyproject.toml ./
RUN uv pip install --system .

# Agent code
COPY agent_minimax.py ./

# Create a minimal Next.js project template
RUN mkdir -p /template && cd /template && \
    npx --yes create-next-app@15.3.0 project \
      --typescript --tailwind --eslint --app --no-src-dir \
      --import-alias "@/*" --turbopack --yes && \
    cd project && npm install && \
    rm -rf .git

RUN ln -sf $(which python3) /usr/local/bin/python
RUN mkdir -p /logs /app/output
